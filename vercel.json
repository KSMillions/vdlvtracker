{
  "version": 2,
  "name": "vdlv-site-tracker",
  "buildCommand": null,
  "outputDirectory": ".",
  "routes": [
    {
      "src": "/(.*\\.css|.*\\.js|.*\\.html|.*\\.ico|.*\\.png|.*\\.webp)",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
